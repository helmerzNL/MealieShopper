# Copy this file to .env.unraid and fill in your own values.

# The Docker Compose file maps host port 5959 to container port 8000 and mounts:
# /mnt/user/appdata/mealieshopper:/data
MEALIESHOPPER_DATA_DIR=/data
MEALIESHOPPER_PUBLIC_BASE_URL=https://mealieshopper.sandmount.nl

# Mealie instance URL without a trailing slash.
# Use a URL that the container can reach.
MEALIE_URL=https://mealie.jouwdomein.nl

# Mealie API token: Mealie > Instellingen > API Tokens.
MEALIE_API_TOKEN=

# Albert Heijn refresh token is optional. Normally you log in through the
# "AH koppelen" tab and the token is encrypted in MEALIESHOPPER_DATA_DIR.
AH_REFRESH_TOKEN=

# Passkey/WebAuthn authentication.
# Keep enabled unless you need a temporary emergency bypass.
PASSKEY_AUTH_ENABLED=true

# Use a long stable random value. Changing it logs everyone out.
MEALIESHOPPER_AUTH_SECRET=change-me-to-a-long-random-string

# Passkeys require HTTPS except on localhost.
# RP_ID is the hostname only, without scheme or port.
# RP_ORIGINS is the full browser URL, comma-separated if you use multiple URLs.
RP_NAME=MealieShopper
RP_ID=mealieshopper.sandmount.nl
RP_ORIGINS=https://mealieshopper.sandmount.nl
